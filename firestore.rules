rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ARCHITECTURE NOTE:
    // This SaaS prototype uses a 100% Custom React Engine where users uniquely log 
    // in by matching their email and plaintext passwords against Firestore natively,
    // thereby skipping Firebase Authentication entirely.
    // As a result, Firebase never automatically issues STS `request.auth` tokens, meaning 
    // ALL read and write operations inside the prototype will be considered UNAUTHENTICATED natively 
    // by this database. 
    // 
    // Therefore, reads and writes MUST completely bypass `isAuthenticated()` validation for 
    // the system workflows to function dynamically.

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
