rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //--------------------------------------------
    // AUTH HELPERS
    //--------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserId() {
      return request.auth.uid;
    }

    //--------------------------------------------
    // SAFE USER DATA FETCH (Fallback system)
    //--------------------------------------------
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(getUserId())).data;
    }

    function getUserInstitution() {
      return ('institutionId' in request.auth.token)
        ? request.auth.token.institutionId
        : getUserData().institutionId;
    }

    function getUserRole() {
      return ('role' in request.auth.token)
        ? request.auth.token.role
        : getUserData().role;
    }

    //--------------------------------------------
    // ROLE CHECKS
    //--------------------------------------------
    function isAdmin() {
      return isAuthenticated() && (getUserRole().upper() == "ADMIN");
    }

    function isHOD() {
      return isAuthenticated() && (getUserRole().upper() == "HOD");
    }

    function isFaculty() {
      return isAuthenticated() && (getUserRole().upper() == "FACULTY");
    }

    function isStudent() {
      return isAuthenticated() && (getUserRole().upper() == "STUDENT");
    }

    //--------------------------------------------
    // INSTITUTION CHECK (SAFE)
    //--------------------------------------------
    function sameInstitutionForRead() {
      return resource.data.institutionId == getUserInstitution();
    }

    function sameInstitutionForWrite() {
      return request.resource.data.institutionId == getUserInstitution();
    }

    //--------------------------------------------
    // USERS
    //--------------------------------------------
    match /users/{userId} {
      allow read, write: if isAuthenticated() && getUserId() == userId;

      allow read: if (isAdmin() || isHOD()) &&
        resource.data.institutionId == getUserInstitution();
    }

    //--------------------------------------------
    // INSTITUTIONS
    //--------------------------------------------
    match /institutions/{institutionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    //--------------------------------------------
    // STUDENTS
    //--------------------------------------------
    match /students/{studentId} {

      allow read: if isStudent() && getUserId() == studentId;

      allow read, write: if (isAdmin() || isHOD()) &&
        sameInstitutionForRead();

      allow create: if (isAdmin() || isHOD()) &&
        sameInstitutionForWrite();
    }

    //--------------------------------------------
    // EXAMS
    //--------------------------------------------
    match /exams/{examId} {
      allow read: if isAuthenticated() && sameInstitutionForRead();
      allow write: if (isAdmin() || isHOD()) && sameInstitutionForWrite();
    }

    //--------------------------------------------
    // SEATING PLANS
    //--------------------------------------------
    match /seatingPlans/{planId} {
      allow read: if isAuthenticated() && sameInstitutionForRead();
      allow write: if isAdmin() && sameInstitutionForWrite();
    }

    //--------------------------------------------
    // ATTENDANCE
    //--------------------------------------------
    match /attendance/{attendanceId} {

      allow read, write: if isFaculty() && sameInstitutionForWrite();

      allow read: if (isAdmin() || isHOD()) && sameInstitutionForRead();

      allow read: if isStudent() &&
        sameInstitutionForRead() &&
        resource.data.studentId == getUserId();
    }

    //--------------------------------------------
    // BLOCKS
    //--------------------------------------------
    match /blocks/{blockId} {
      allow read: if isAuthenticated() && sameInstitutionForRead();

      allow create: if isAdmin() && sameInstitutionForWrite();

      allow update, delete: if isAdmin() && sameInstitutionForRead();
    }

    //--------------------------------------------
    // CLASSROOMS
    //--------------------------------------------
    match /classrooms/{classroomId} {

      allow read: if isAuthenticated() && sameInstitutionForRead();

      allow create: if (isAdmin() || isHOD()) &&
        sameInstitutionForWrite();

      allow update, delete: if (isAdmin() || isHOD()) &&
        sameInstitutionForRead();
    }

    //--------------------------------------------
    // BRANCHES
    //--------------------------------------------
    match /branches/{branchId} {
      allow read: if isAuthenticated() && sameInstitutionForRead();
      allow create: if isAdmin() && sameInstitutionForWrite();
      allow update, delete: if isAdmin() && sameInstitutionForRead();
    }

    //--------------------------------------------
    // HODS
    //--------------------------------------------
    match /hods/{hodId} {
      allow read: if isAuthenticated() && sameInstitutionForRead();
      allow create: if isAdmin() && sameInstitutionForWrite();
      allow update, delete: if isAdmin() && sameInstitutionForRead();
    }

    //--------------------------------------------
    // FACULTY
    //--------------------------------------------
    match /faculty/{facultyId} {
      allow read: if isAuthenticated() && sameInstitutionForRead();
      allow create: if (isAdmin() || isHOD()) && sameInstitutionForWrite();
      allow update, delete: if (isAdmin() || isHOD()) && sameInstitutionForRead();
    }

  }
}